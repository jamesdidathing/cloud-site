    <div class="actions">
        <a href="/projects/" class="btn primary">view my work</a>
        <a href="/about/" class="btn">about me</a>
    </div>

    <div class="social-row">
        <a href="https://github.com/jamesdidathing" target="_blank">GitHub</a>
        <span class="sep">/</span>
        <a href="https://www.linkedin.com/in/james-a-hodson/" target="_blank">LinkedIn</a>
