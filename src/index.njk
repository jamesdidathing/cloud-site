<script>
    fetch('https://james-hodson.com/count')
        .then(response => response.json())
        .then(data => {
            document.getElementById('visitor-count').innerText = data.count.toLocaleString();
        })
        .catch(error => {
            document.getElementById('visitor-count').innerText = '?';
        });
</script>
