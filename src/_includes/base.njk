<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="site-nav">
        <div class="nav-inner">
            <a href="/" class="brand">~/james-hodson</a>
            <ul class="nav-links">
                <li><a href="/"{% if page.url == "/" %} class="active"{% endif %}>home</a></li>
                <li><a href="/about/"{% if page.url == "/about/" %} class="active"{% endif %}>about</a></li>
                <li><a href="/projects/"{% if page.url == "/projects/" %} class="active"{% endif %}>projects</a></li>
                <li><a href="/blog/"{% if "/blog" in page.url %} class="active"{% endif %}>blog</a></li>
                <li><a href="/contact/"{% if page.url == "/contact/" %} class="active"{% endif %}>contact</a></li>
            </ul>
        </div>
    </nav>

    <main class="page">
        {{ content | safe }}
    </main>

    <footer class="site-footer">
        <p>built with Eleventy · hosted on AWS · deployed by GitHub Actions</p>
    </footer>
</body>
</html>
